<?xml version="1.0" encoding="utf-8"?>
<!--
  LocalReactivePolice.vcxproj
  Visual Studio 2019 / 2022 — GTA SA plugin-sdk project

  INSTRUÇÕES DE SETUP:
  1. Clonar plugin-sdk: https://github.com/DK22Pac/plugin-sdk
  2. Definir variável de ambiente: PLUGIN_SDK_DIR=C:\path\to\plugin-sdk
  3. Abrir este .vcxproj no Visual Studio
  4. Build → Release → LocalReactivePolice.asi aparece em /bin/
  5. Copiar o .asi para a pasta raiz do GTA San Andreas
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|Win32">
      <Configuration>Debug</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>LocalReactivePolice</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <!-- ── Release ── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v142</PlatformToolset>
    <CharacterSet>MultiByte</CharacterSet>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>

  <!-- ── Debug ── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v142</PlatformToolset>
    <CharacterSet>MultiByte</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- ── Output paths ── -->
  <PropertyGroup>
    <OutDir>$(SolutionDir)bin\$(Configuration)\</OutDir>
    <IntDir>$(SolutionDir)obj\$(Configuration)\</IntDir>
    <TargetExtension>.asi</TargetExtension>
    <TargetName>LocalReactivePolice</TargetName>
  </PropertyGroup>

  <!-- ── Compiler & Linker (Release) ── -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>

      <!-- plugin-sdk include paths (requer variável PLUGIN_SDK_DIR) -->
      <AdditionalIncludeDirectories>
        $(PLUGIN_SDK_DIR)\plugin_sa;
        $(PLUGIN_SDK_DIR)\plugin_sa\game_sa;
        $(PLUGIN_SDK_DIR)\shared;
        $(PLUGIN_SDK_DIR)\shared\game;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>

      <PreprocessorDefinitions>
        NDEBUG;
        _WINDOWS;
        _USRDLL;
        _CRT_SECURE_NO_WARNINGS;
        PLUGIN_SGV_10US;
        %(PreprocessorDefinitions)
      </PreprocessorDefinitions>

      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <LanguageStandard>stdcpp17</LanguageStandard>
    </ClCompile>

    <Link>
      <SubSystem>Windows</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>

      <!-- Libs do plugin-sdk -->
      <AdditionalLibraryDirectories>
        $(PLUGIN_SDK_DIR)\output\lib;
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>

      <AdditionalDependencies>
        plugin.lib;
        %(AdditionalDependencies)
      </AdditionalDependencies>

      <!-- Necessário para .asi não precisar de DLL runtime -->
      <IgnoreAllDefaultLibraries>false</IgnoreAllDefaultLibraries>
    </Link>
  </ItemDefinitionGroup>

  <!-- ── Compiler & Linker (Debug) ── -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>Disabled</Optimization>

      <AdditionalIncludeDirectories>
        $(PLUGIN_SDK_DIR)\plugin_sa;
        $(PLUGIN_SDK_DIR)\plugin_sa\game_sa;
        $(PLUGIN_SDK_DIR)\shared;
        $(PLUGIN_SDK_DIR)\shared\game;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>

      <PreprocessorDefinitions>
        _DEBUG;
        _WINDOWS;
        _USRDLL;
        _CRT_SECURE_NO_WARNINGS;
        PLUGIN_SGV_10US;
        %(PreprocessorDefinitions)
      </PreprocessorDefinitions>

      <RuntimeLibrary>MultiThreadedDebug</RuntimeLibrary>
      <LanguageStandard>stdcpp17</LanguageStandard>
    </ClCompile>

    <Link>
      <SubSystem>Windows</SubSystem>
      <AdditionalLibraryDirectories>
        $(PLUGIN_SDK_DIR)\output\lib;
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>
      <AdditionalDependencies>
        plugin.lib;
        %(AdditionalDependencies)
      </AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <!-- ── Source files ── -->
  <ItemGroup>
    <ClCompile Include="LocalReactivePolice.cpp" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
